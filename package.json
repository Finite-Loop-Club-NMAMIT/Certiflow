{
  "name": "Certiflow",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "better-auth": "1.6.23",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @Certiflow/db",
    "db:studio": "turbo run db:studio -F @Certiflow/db",
    "db:generate": "turbo run db:generate -F @Certiflow/db",
    "db:migrate": "turbo run db:migrate -F @Certiflow/db",
    "db:start": "turbo run db:start -F @Certiflow/db",
    "db:watch": "turbo run db:watch -F @Certiflow/db",
    "db:stop": "turbo run db:stop -F @Certiflow/db",
    "db:down": "turbo run db:down -F @Certiflow/db"
  },
  "dependencies": {
    "@Certiflow/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Certiflow/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
